  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 42f40a9881777504b83ab326f3c1273f, type: 3}
  dialogText: "Para cerrar, veamos casos reales donde se omitieron las reglas de
    oro. En el primer caso, un trabajador omiti\xF3 el corte visible y confi\xF3
    en que el equipo estaba apagado. En el segundo, alguien retir\xF3 el candado
    de otro sin autorizaci\xF3n. En el tercero, no se verific\xF3 la ausencia de
    tensi\xF3n."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
  - normalizedTime: 0
    clip: {fileID: 7400000, guid: 712260ab53820bf4fbf348f498656857, type: 2}
  - normalizedTime: 0.37830135
