  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: ca71c4be003ab4b4f9fb51725965fbc1, type: 3}
  dialogText: "Una vez que el corte visible est\xE1 hecho, debemos asegurarnos de
    que nadie pueda cerrarlo accidentalmente. Cada trabajador coloca su candado personal
    y su tarjeta de seguridad en el punto de bloqueo. Mientras haya al menos un candado
    puesto, el equipo no puede reenergizarse."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
  - normalizedTime: 0
    clip: {fileID: 7400000, guid: 712260ab53820bf4fbf348f498656857, type: 2}
