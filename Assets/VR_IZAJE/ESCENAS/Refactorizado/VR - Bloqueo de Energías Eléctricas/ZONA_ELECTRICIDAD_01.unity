  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 5f42bddaba400cc4e830a86c73ec822f, type: 3}
  dialogText: "Bienvenido al m\xF3dulo de capacitaci\xF3n en Bloqueo de Energ\xEDas
    El\xE9ctricas. Soy tu gu\xEDa virtual y te acompa\xF1ar\xE9 en cada paso de esta
    experiencia. El bloqueo de energ\xEDas es un procedimiento de seguridad obligatorio
    que evita la activaci\xF3n accidental de equipos durante trabajos de mantenimiento
    o reparaci\xF3n.\n"
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
