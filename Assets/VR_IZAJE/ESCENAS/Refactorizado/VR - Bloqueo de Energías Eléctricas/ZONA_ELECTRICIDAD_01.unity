  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: c5c7b4d660ebd7747a1ed3a0dd1568de, type: 3}
  dialogText: "La puesta a tierra y cortocircuito es nuestra red de seguridad. Conectamos
    cables conductores desde las l\xEDneas del circuito hasta una barra de tierra,
    creando un camino seguro para que cualquier energ\xEDa residual o accidental
    se disipe. Esto nos protege incluso si alguien reenergiza el sistema por error."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
