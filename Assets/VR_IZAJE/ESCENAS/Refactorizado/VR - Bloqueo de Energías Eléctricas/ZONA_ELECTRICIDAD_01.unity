  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: a26c51b4c468edb4198224d5e529c3b9, type: 3}
  dialogText: "El EPP es tu \xFAltima l\xEDnea de defensa. Para trabajos el\xE9ctricos
    necesitas: casco diel\xE9ctrico con barbuquejo, guantes aislantes clase acorde
    a la tensi\xF3n, protector facial contra arco el\xE9ctrico, ropa ign\xEDfuga
    y calzado diel\xE9ctrico. Cada elemento tiene una funci\xF3n vital."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
  - normalizedTime: 0
    clip: {fileID: 7400000, guid: 712260ab53820bf4fbf348f498656857, type: 2}
  - normalizedTime: 0.37830135
    clip: {fileID: 7400000, guid: d7ef867cd13e2d441a3c61b68beed7f2, type: 2}
