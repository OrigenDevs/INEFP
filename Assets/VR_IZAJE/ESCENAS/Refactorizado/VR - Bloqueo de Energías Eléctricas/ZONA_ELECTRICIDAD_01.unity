  voiceClip: {fileID: 8300000, guid: a481b8a4fc52faa47955830469b5a66a, type: 3}
  dialogText: "Existen varios tipos de energ\xEDa peligrosa: el\xE9ctrica, mec\xE1nica,
    neum\xE1tica, hidr\xE1ulica, t\xE9rmica, qu\xEDmica y hasta la gravedad. Cada
    una requiere un m\xE9todo de bloqueo espec\xEDfico. En este curso nos centraremos
    \xFAnicamente en la energ\xEDa el\xE9ctrica, una de las m\xE1s letales y comunes
    en la industria."
