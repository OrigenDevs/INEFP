--- !u!114 &2122151423
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2122151421}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: ab3e590364415104cb624cb67f92350f, type: 3}
  dialogText: "Las 5 Reglas de Oro son la base de la seguridad el\xE9ctrica a nivel
    mundial. Piensa en ellas como una escalera: debes subir cada pelda\xF1o en orden,
    sin saltarte ninguno. Si omites una sola regla, toda la seguridad de la maniobra
    queda invalidada y el riesgo de accidente es inminente."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
  - normalizedTime: 0
    clip: {fileID: 7400000, guid: 712260ab53820bf4fbf348f498656857, type: 2}
  - normalizedTime: 0.37830135
    clip: {fileID: 7400000, guid: d7ef867cd13e2d441a3c61b68beed7f2, type: 2}
  objectsToActivate: []
  objectsToDeactivate: []
