  voiceClip: {fileID: 8300000, guid: 3e16588d82676104c85d526e159f7376, type: 3}
  dialogText: "Ahora cada trabajador debe retirar su propio candado personal y su
    tarjeta de seguridad. Esta es una regla absoluta: nadie puede retirar el candado
    de otro trabajador. Si alguien no est\xE1 presente para retirar su candado, el
    supervisor debe seguir un protocolo especial de verificaci\xF3n."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
