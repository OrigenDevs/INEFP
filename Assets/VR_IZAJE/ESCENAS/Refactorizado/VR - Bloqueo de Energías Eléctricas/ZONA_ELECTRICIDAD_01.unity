  voiceClip: {fileID: 8300000, guid: c94d08fe50d3d834e9206e3a8c6f8a50, type: 3}
  dialogText: "Cada a\xF1o ocurren cientos de accidentes el\xE9ctricos graves por
    no aplicar un correcto bloqueo de energ\xEDas. Electrocuci\xF3n, arco el\xE9ctrico,
    quemaduras severas. Todos estos incidentes son prevenibles si seguimos el procedimiento
    establecido por normas como OSHA y el DS 594 chileno."
  textDelay: 3
  autoAvanzar: 0
  sonidoAlAvanzar: 0
