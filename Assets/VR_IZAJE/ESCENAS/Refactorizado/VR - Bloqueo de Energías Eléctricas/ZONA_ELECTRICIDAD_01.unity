  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 1bbfa76fe8c68d64ebfc2e33189c581e, type: 3}
  dialogText: "El trabajador autorizado es la persona que ejecuta la tarea. Sus responsabilidades
    incluyen: aplicar las 5 reglas de oro en orden, colocar su candado personal en
    el panel de bloqueo colectivo, verificar la ausencia de tensi\xF3n con su propio
    detector, y retirar su candado \xFAnicamente al terminar su labor."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
  - normalizedTime: 0
    clip: {fileID: 7400000, guid: 712260ab53820bf4fbf348f498656857, type: 2}
