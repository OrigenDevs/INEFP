  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 964368f0d2ad50b47992e1b9b0a5d346, type: 3}
  dialogText: "Lo \xFAltimo que retiramos es la se\xF1alizaci\xF3n de seguridad.
    Las cintas, conos y barreras se recogen solo cuando el sistema ya est\xE1 energizado
    y funcionando correctamente. Esto evita que alguien ingrese al \xE1rea mientras
    a\xFAn se est\xE1n realizando maniobras de restablecimiento."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
