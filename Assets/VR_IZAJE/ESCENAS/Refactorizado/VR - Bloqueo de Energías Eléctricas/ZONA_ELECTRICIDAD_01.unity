  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: a93b2603f1628db4b82534b488fd5c45, type: 3}
  dialogText: "Antes de tocar cualquier componente debemos verificar que no haya
    voltaje presente. Se usa un detector de tensi\xF3n certificado, prob\xE1ndolo
    primero en una fuente conocida para asegurarnos de que funciona. Luego se mide
    entre cada fase, entre fases y neutro, y entre fases y tierra."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
  - normalizedTime: 0
    clip: {fileID: 7400000, guid: 712260ab53820bf4fbf348f498656857, type: 2}
  - normalizedTime: 0.37830135
    clip: {fileID: 7400000, guid: d7ef867cd13e2d441a3c61b68beed7f2, type: 2}
