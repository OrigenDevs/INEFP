  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 8e6e597edb19f5344828ddf559f731f3, type: 3}
  dialogText: "Aunque el equipo donde trabajamos est\xE9 desenergizado, puede haber
    otros equipos cercanos que sigan energizados. Debemos delimitar nuestra zona
    de trabajo con cintas y conos, y cubrir las partes activas vecinas con mantas
    aislantes. Esto evita contactos accidentales."
  textDelay: 3
  autoAvanzar: 1
  sonidoAlAvanzar: 0
  animationTimeline:
