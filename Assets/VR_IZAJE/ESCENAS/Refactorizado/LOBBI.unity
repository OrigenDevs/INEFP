  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: bbebe83d741703948bb819a3d4628256, type: 3}
  dialogText: "Para elegir bien hay que considerar el peso de la carga, el tipo de
    material, el \xE1ngulo de los ramales y el ambiente de trabajo. Por ejemplo:
    para una carga de 1.500 kilos, usando dos eslingas textiles a 45 grados, necesitar\xE1s
    eslingas verdes de 60 mil\xEDmetros con CMU de 2.000 kilos, y grilletes de 2
    toneladas."
  textDelay: 2
  autoAvanzar: 0
  sonidoAlAvanzar: 1
