  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 9d5f7dc7f951948489df605e0d182474, type: 3}
  dialogText: "Ahora trabajaremos en la mesa de inspecci\xF3n. Aqu\xED revisaremos
    los equipos uno por uno. Lo primero es comprobar que todos los elementos y sistemas
    de seguridad est\xE9n operativos. Selecciona los elementos para equiparlos en
    nuestro inventario."
